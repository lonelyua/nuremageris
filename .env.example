PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=nuremageris
PG_USER=bench
PG_PASSWORD=bench

# Pool size — applied to all adapters
PG_POOL_MIN=2
PG_POOL_MAX=10

# How long (ms) to wait for a free connection from the pool before throwing
PG_POOL_CONNECTION_TIMEOUT_MS=5000

# How long (ms) an idle connection is kept alive before being closed
PG_POOL_IDLE_TIMEOUT_MS=30000

# S | M | L
SEED_SIZE=M

